<%
	var tagList = page.tags ? page.tags.toArray() : [];
%>

<article class="doc-page-layout" data-doc-toc-root>
	<section class="doc-page-main">
		<header class="doc-page-header">
			<div class="doc-page-meta">
				<span><%= page.date.format('YYYY-MM-DD') %></span>
				<% if (page.updated) { %>
					<span>更新于 <%= page.updated.format('YYYY-MM-DD') %></span>
				<% } %>
			</div>
			<h1><%= page.title %></h1>
			<% if (page.desc) { %>
				<p class="doc-card-summary"><%= page.desc %></p>
			<% } %>
			<% if (tagList.length) { %>
				<div class="doc-page-tags">
					<% tagList.forEach(function(tag){ %>
						<a href="<%- url_for('/?tag=' + encodeURIComponent(tag.name)) %>"><%= tag.name %></a>
					<% }) %>
				</div>
			<% } %>
		</header>

		<div class="doc-content" data-doc-content>
			<%- page.content %>
		</div>
	</section>

	<%- partial('_partial/doc-toc', { tocLabel: '文章目录', emptyText: '当前文章没有可用目录。' }) %>
</article>
