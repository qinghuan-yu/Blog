<article class="doc-page-layout" data-doc-toc-root>
	<section class="doc-page-main">
		<header class="doc-page-header">
			<p class="section-kicker">Page</p>
			<h1><%= page.title %></h1>
		</header>

		<div class="doc-content" data-doc-content>
			<%- page.content %>
		</div>
	</section>

	<%- partial('_partial/doc-toc', { tocLabel: '本页目录', emptyText: '当前页面没有可用目录。' }) %>
</article>
